# ── MongoDB ──────────────────────────────────────────────────────────────────
# Local:   mongodb://localhost:27017
# Atlas:   mongodb+srv://user:pass@cluster.mongodb.net
MONGODB_URI=mongodb+srv://new_user:newdb@cluster0.znaoocm.mongodb.net/?appName=Cluster0
MONGODB_DB=flowai

# ── JWT ──────────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=dd775a5791c8549230f27033ca7ae4baf4ca55138f927fffdd02f39d46ce6a4f
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7

# ── Firebase / Google Auth ───────────────────────────────────────────────────
# Get from: Firebase Console → Project Settings → General
# The project ID is the string like "my-app-12345"
FIREBASE_PROJECT_ID=flowai-8006d

# ── Gemini AI ────────────────────────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSyBsxC7sdKKrbuRmm7zxBMzugLnE4AO9_BI

# ── Groq AI (FREE fallback when Gemini quota exceeded) ───────────────────────
# Get FREE key from: https://console.groq.com/keys (no credit card needed!)
# This provides Llama 3.3 70B as backup for AI insights
GROQ_API_KEY=
# ── App ──────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
PORT=8000
CORS_ORIGINS=http://localhost:5173

# ── Data ─────────────────────────────────────────────────────────────────────
CSV_PATH=data/employee_app_activity_v2.csv

# ── Actuation Webhook (optional) ──────────────────────────────────────────────
# Leave empty for dev — actuations are logged to console and MongoDB only.
# Set to a Slack webhook URL or any HTTP endpoint for real integrations.
ACTUATION_WEBHOOK_URL=https://hooks.slack.com/services/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

# ── Anonymisation ─────────────────────────────────────────────────────────────
# HMAC key for irreversible emp_id anonymisation in webhooks & LLM prompts
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
ANON_HMAC_KEY=f1e98b29b1522e4ef6c6a4480b451456cdf2b9117e5aaf8a553ab4aa2da87dfd

# ── Differential Privacy ─────────────────────────────────────────────────────
# epsilon budget for Laplacian noise (lower = stronger privacy, more noise)
# Recommended: 0.5 (strict) to 2.0 (lenient). Default: 1.0
DP_EPSILON=1.0
